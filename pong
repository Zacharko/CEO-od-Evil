<script>
const canvas = document.getElementById('pong-canvas');
const ctx = canvas.getContext('2d');
const W = canvas.width;
const H = canvas.height;

const PADDLE_W = 12, PADDLE_H = 80, BALL_R = 8;
const WIN_SCORE = 7;
const COLORS = { paddle: '#00FF00', ball: '#00FF00', mid: '#1a4a1a', bg: '#000' };

let state = 'idle'; // idle, playing, paused, gameover
let scoreL = 0, scoreR = 0;
let keys = {};

let lPaddle = { x: 18, y: H/2 - PADDLE_H/2, dy: 0 };
let rPaddle = { x: W - 18 - PADDLE_W, y: H/2 - PADDLE_H/2 };
let ball = { x: W/2, y: H/2, dx: 4, dy: 3 };
let winner = '';

function resetBall(dir) {
  ball.x = W/2;
  ball.y = H/2;
  ball.dx = (dir || (Math.random()>0.5?1:-1)) * 4;
  ball.dy = (Math.random()>0.5?1:-1) * 3;
}

function resetGame() {
  scoreL = 0; scoreR = 0;
  lPaddle.y = H/2 - PADDLE_H/2;
  rPaddle.y = H/2 - PADDLE_H/2;
  resetBall();
  state = 'idle';
  winner = '';
  document.getElementById('score-left').textContent = '0';
  document.getElementById('score-right').textContent = '0';
  setStatus('// STLAC [ENTER] PRE SPUSTENIE // W/S = HRAC // Q = PAUZA //');
  draw();
}

function startGame() {
  if (state === 'gameover') resetGame();
  state = 'playing';
  setStatus('// HRACI SA // W/S = HORE/DOLE // Q = PAUZA //');
}

function pauseGame() {
  if (state === 'playing') { state = 'paused'; setStatus('// PAUZA // STLAC [ENTER] PRE POKRACOVANIE //'); }
  else if (state === 'paused') { state = 'playing'; setStatus('// HRACI SA //'); }
}

function setStatus(txt) {
  document.getElementById('status-bar').textContent = txt;
}

document.addEventListener('keydown', e => {
  keys[e.key] = true;
  if (e.key === 'Enter') { if(state==='idle'||state==='paused') startGame(); }
  if (e.key === 'q' || e.key === 'Q') pauseGame();
  if (e.key === 'w' || e.key === 'W' || e.key === 's' || e.key === 'S') e.preventDefault();
});
document.addEventListener('keyup', e => { keys[e.key] = false; });

function update() {
  if (state !== 'playing') return;

  // Player paddle
  const SPEED = 6;
  if ((keys['w'] || keys['W']) && lPaddle.y > 0) lPaddle.y -= SPEED;
  if ((keys['s'] || keys['S']) && lPaddle.y + PADDLE_H < H) lPaddle.y += SPEED;

  // AI paddle - sleduje lopticku s malou chybou
  const aiTarget = ball.y - PADDLE_H/2 + (Math.random()-0.5)*20;
  const aiSpeed = 4.5;
  if (rPaddle.y + PADDLE_H/2 < aiTarget) rPaddle.y = Math.min(rPaddle.y + aiSpeed, H - PADDLE_H);
  else if (rPaddle.y + PADDLE_H/2 > aiTarget) rPaddle.y = Math.max(rPaddle.y - aiSpeed, 0);

  // Ball movement
  ball.x += ball.dx;
  ball.y += ball.dy;

  // Wall bounce top/bottom
  if (ball.y - BALL_R <= 0) { ball.y = BALL_R; ball.dy = Math.abs(ball.dy); }
  if (ball.y + BALL_R >= H) { ball.y = H - BALL_R; ball.dy = -Math.abs(ball.dy); }

  // Left paddle collision
  if (ball.x - BALL_R <= lPaddle.x + PADDLE_W &&
      ball.x - BALL_R >= lPaddle.x &&
      ball.y >= lPaddle.y && ball.y <= lPaddle.y + PADDLE_H) {
    ball.x = lPaddle.x + PADDLE_W + BALL_R;
    ball.dx = Math.abs(ball.dx) * 1.05;
    ball.dy += (ball.y - (lPaddle.y + PADDLE_H/2)) * 0.1;
    ball.dx = Math.min(ball.dx, 12);
  }

  // Right paddle collision
  if (ball.x + BALL_R >= rPaddle.x &&
      ball.x + BALL_R <= rPaddle.x + PADDLE_W &&
      ball.y >= rPaddle.y && ball.y <= rPaddle.y + PADDLE_H) {
    ball.x = rPaddle.x - BALL_R;
    ball.dx = -Math.abs(ball.dx) * 1.05;
    ball.dy += (ball.y - (rPaddle.y + PADDLE_H/2)) * 0.1;
    ball.dx = Math.max(ball.dx, -12);
  }

  // Scoring
  if (ball.x < 0) {
    scoreR++;
    document.getElementById('score-right').textContent = scoreR;
    if (scoreR >= WIN_SCORE) { state = 'gameover'; winner = 'AI // REPTILIAN'; setStatus('// AI VYHRAL // REPTILIANSKA KONTROLA OBNOVENA // RESET = SKUS ZNOVA //'); return; }
    resetBall(1);
  }
  if (ball.x > W) {
    scoreL++;
    document.getElementById('score-left').textContent = scoreL;
    if (scoreL >= WIN_SCORE) { state = 'gameover'; winner = 'HRAC // CLOVEN'; setStatus('// TY VYHRAL // DEEPSTATE NEUTRALIZOVANY // RESET PRE NOVU HRU //'); return; }
    resetBall(-1);
  }
}

function drawGlowRect(x, y, w, h, color) {
  ctx.save();
  ctx.shadowColor = color;
  ctx.shadowBlur = 12;
  ctx.fillStyle = color;
  ctx.fillRect(x, y, w, h);
  ctx.restore();
}

function drawGlowCircle(x, y, r, color) {
  ctx.save();
  ctx.shadowColor = color;
  ctx.shadowBlur = 14;
  ctx.fillStyle = color;
  ctx.beginPath();
  ctx.arc(x, y, r, 0, Math.PI*2);
  ctx.fill();
  ctx.restore();
}

function draw() {
  // Background
  ctx.fillStyle = COLORS.bg;
  ctx.fillRect(0, 0, W, H);

  // Center dashed line
  ctx.setLineDash([8,8]);
  ctx.strokeStyle = '#0d2e0d';
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.moveTo(W/2, 0);
  ctx.lineTo(W/2, H);
  ctx.stroke();
  ctx.setLineDash([]);

  // Center circle
  ctx.strokeStyle = '#0d2e0d';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.arc(W/2, H/2, 50, 0, Math.PI*2);
  ctx.stroke();

  // Paddles
  drawGlowRect(lPaddle.x, lPaddle.y, PADDLE_W, PADDLE_H, '#00FF00');
  drawGlowRect(rPaddle.x, rPaddle.y, PADDLE_W, PADDLE_H, '#00aa00');

  // Ball
  drawGlowCircle(ball.x, ball.y, BALL_R, '#00FF00');

  // Game Over overlay
  if (state === 'gameover') {
    ctx.fillStyle = 'rgba(0,5,0,0.75)';
    ctx.fillRect(0, 0, W, H);
    ctx.font = 'bold 28px Orbitron, monospace';
    ctx.fillStyle = '#00FF00';
    ctx.textAlign = 'center';
    ctx.shadowColor = '#00FF00';
    ctx.shadowBlur = 18;
    ctx.fillText('// KONIEC HRY //', W/2, H/2 - 24);
    ctx.font = '13px Orbitron, monospace';
    ctx.fillStyle = '#7dc87d';
    ctx.shadowBlur = 6;
    ctx.fillText(winner + ' VYHRAL', W/2, H/2 + 10);
    ctx.font = '9px Orbitron, monospace';
    ctx.fillStyle = '#2a5a2a';
    ctx.shadowBlur = 0;
    ctx.fillText('[ RESET ] PRE NOVU HRU', W/2, H/2 + 36);
    ctx.textAlign = 'left';
    ctx.shadowBlur = 0;
  }

  // Idle overlay
  if (state === 'idle') {
    ctx.fillStyle = 'rgba(0,5,0,0.65)';
    ctx.fillRect(0, 0, W, H);
    ctx.font = 'bold 14px Orbitron, monospace';
    ctx.fillStyle = '#00FF00';
    ctx.textAlign = 'center';
    ctx.shadowColor = '#00FF00';
    ctx.shadowBlur = 12;
    ctx.fillText('// PONG // CEO ZLA EDITION //', W/2, H/2 - 16);
    ctx.font = '9px Orbitron, monospace';
    ctx.fillStyle = '#458c3a';
    ctx.shadowBlur = 0;
    ctx.fillText('STLAC [ENTER] alebo [ SPUSTI ] pre zaciatok', W/2, H/2 + 14);
    ctx.textAlign = 'left';
  }

  // Paused overlay
  if (state === 'paused') {
    ctx.fillStyle = 'rgba(0,5,0,0.6)';
    ctx.fillRect(0, 0, W, H);
    ctx.font = 'bold 18px Orbitron, monospace';
    ctx.fillStyle = '#7dc87d';
    ctx.textAlign = 'center';
    ctx.shadowColor = '#00FF00';
    ctx.shadowBlur = 10;
    ctx.fillText('// PAUZA //', W/2, H/2);
    ctx.font = '9px Orbitron, monospace';
    ctx.fillStyle = '#458c3a';
    ctx.shadowBlur = 0;
    ctx.fillText('[ENTER] alebo [ PAUZA ] pre pokracovanie', W/2, H/2 + 22);
    ctx.textAlign = 'left';
  }
}

function loop() {
  update();
  draw();
  requestAnimationFrame(loop);
}

// Init
draw();
loop();
</script>

